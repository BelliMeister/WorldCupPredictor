# Copy this file to .secrets.env and fill in your real keys.
# .secrets.env is gitignored and will NOT be pushed to GitHub.

# football-data.org (live WC results)  — https://www.football-data.org
FOOTBALL_DATA_API_KEY=your_football_data_key_here

# API-Football (per-player stats)      — https://www.api-football.com
API_FOOTBALL_KEY=your_api_football_key_here
